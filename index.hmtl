</nav>

<!-- HERO -->
<div class="hero" id="hero-top">
  <span class="hero-badge">Learn With iKay · Module 1</span>
  <h1>Excel for Data Analysis</h1>
  <p>Master the essential Excel skills every data analyst needs — from formulas and functions to PivotTables and charts.</p>
  <div class="hero-stats">
    <div class="stat-item"><span class="num">9</span><span class="lbl">Topics</span></div>
    <div class="stat-item"><span class="num">60+</span><span class="lbl">Formulas</span></div>
    <div class="stat-item"><span class="num">30+</span><span class="lbl">Shortcuts</span></div>
    <div class="stat-item"><span class="num">10</span><span class="lbl">Quiz Questions</span></div>
  </div>
</div>

