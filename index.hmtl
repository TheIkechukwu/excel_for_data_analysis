<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Excel for Data Analysis – Learn With iKay</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=EB+Garamond:wght@400;500&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --dark-green: #0B4619;
    --bright-green: #2E7D32;
    --light-green: #4CAF50;
    --pale-green: #E8F5E9;
    --accent-green: #00C853;
    --white: #ffffff;
    --off-white: #f9fdf9;
    --text-dark: #1a2e1a;
    --text-muted: #4a6b4a;
    --border: #c8e6c9;
    --shadow: rgba(11,70,25,0.12);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: "Lato", sans-serif;
    background: var(--white);
    color: var(--text-dark);
    line-height: 1.7;
  }

  /* NAV */
  nav {
    background: var(--dark-green);
    padding: 12px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 1000;
    box-shadow: 0 2px 16px rgba(0,0,0,0.3);
  }
  nav img { height: 52px; }
  nav .nav-title {
    font-family: "Playfair Display", serif;
    color: var(--white);
    font-size: 1.15rem;
    letter-spacing: 0.5px;
  }
  nav .nav-links {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  nav .nav-links a {
    color: #b9e4be;
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 20px;
    border: 1px solid transparent;
    transition: all 0.25s;
    letter-spacing: 0.3px;
  }
  nav .nav-links a:hover, nav .nav-links a.active {
    background: var(--accent-green);
    color: var(--dark-green);
    border-color: var(--accent-green);
  }

  /* HERO */
  .hero {
    background: linear-gradient(135deg, var(--dark-green) 0%, var(--bright-green) 100%);
    color: var(--white);
    padding: 80px 40px 60px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    top: -60px; right: -60px;
    width: 300px; height: 300px;
    background: rgba(255,255,255,0.04);
    border-radius: 50%;
  }
  .hero::after {
    content: "";
    position: absolute;
    bottom: -80px; left: -40px;
    width: 250px; height: 250px;
    background: rgba(0,200,83,0.1);
    border-radius: 50%;
  }
  .hero-badge {
    display: inline-block;
    background: var(--accent-green);
    color: var(--dark-green);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 18px;
  }
  .hero h1 {
    font-family: "Playfair Display", serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    margin-bottom: 16px;
    line-height: 1.25;
  }
  .hero p {
    font-size: 1.05rem;
    color: #b9e4be;
    max-width: 600px;
    margin: 0 auto 30px;
    font-family: "EB Garamond", serif;
    font-size: 1.1rem;
  }
  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 40px;
    margin-top: 10px;
    flex-wrap: wrap;
  }
  .stat-item { text-align: center; }
  .stat-item .num {
    font-family: "Playfair Display", serif;
    font-size: 2rem;
    color: var(--accent-green);
    display: block;
  }
  .stat-item .lbl {
    font-size: 0.78rem;
    color: #b9e4be;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* MAIN LAYOUT */
  .layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    min-height: calc(100vh - 77px);
  }

  /* SIDEBAR */
  .sidebar {
    background: var(--off-white);
    border-right: 2px solid var(--border);
    padding: 30px 0;
    position: sticky;
    top: 77px;
    height: calc(100vh - 77px);
    overflow-y: auto;
  }
  .sidebar-section {
    margin-bottom: 8px;
  }
  .sidebar-section h3 {
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    padding: 8px 22px 4px;
  }
  .sidebar a {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 9px 22px;
    text-decoration: none;
    color: var(--text-dark);
    font-size: 0.86rem;
    font-weight: 400;
    border-left: 3px solid transparent;
    transition: all 0.2s;
    cursor: pointer;
  }
  .sidebar a:hover, .sidebar a.active {
    background: var(--pale-green);
    color: var(--dark-green);
    border-left-color: var(--accent-green);
    font-weight: 700;
  }
  .sidebar a .icon { font-size: 1rem; }

  /* CONTENT */
  .content {
    padding: 40px 50px;
    max-width: 960px;
  }

  .section { display: none; }
  .section.active { display: block; }

  /* SECTION HEADING */
  .section-header {
    margin-bottom: 32px;
    padding-bottom: 16px;
    border-bottom: 2px solid var(--border);
  }
  .section-header .tag {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--bright-green);
    margin-bottom: 6px;
    display: block;
  }
  .section-header h2 {
    font-family: "Playfair Display", serif;
    font-size: 2rem;
    color: var(--dark-green);
    margin-bottom: 8px;
  }
  .section-header p {
    color: var(--text-muted);
    font-family: "EB Garamond", serif;
    font-size: 1.05rem;
  }

  /* CARDS */
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
    margin: 24px 0;
  }
  .card {
    background: var(--white);
    border: 1.5px solid var(--border);
    border-radius: 12px;
    padding: 22px;
    transition: all 0.25s;
    cursor: pointer;
  }
  .card:hover {
    border-color: var(--accent-green);
    box-shadow: 0 6px 24px var(--shadow);
    transform: translateY(-2px);
  }
  .card .card-icon {
    width: 44px; height: 44px;
    background: var(--pale-green);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    margin-bottom: 14px;
  }
  .card h4 {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--dark-green);
    margin-bottom: 6px;
  }
  .card p {
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.55;
  }

  /* CONTENT BLOCKS */
  .content-block {
    background: var(--white);
    border: 1.5px solid var(--border);
    border-radius: 12px;
    padding: 28px 32px;
    margin-bottom: 24px;
  }
  .content-block h3 {
    font-family: "Playfair Display", serif;
    font-size: 1.35rem;
    color: var(--dark-green);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .content-block p, .content-block li {
    font-size: 0.92rem;
    color: var(--text-dark);
    margin-bottom: 8px;
    line-height: 1.7;
  }
  .content-block ul, .content-block ol {
    padding-left: 20px;
    margin-bottom: 12px;
  }

  /* CODE / FORMULA BLOCKS */
  .formula-box {
    background: var(--dark-green);
    color: var(--accent-green);
    font-family: "Courier New", monospace;
    font-size: 0.9rem;
    padding: 14px 18px;
    border-radius: 8px;
    margin: 12px 0;
    overflow-x: auto;
    border-left: 4px solid var(--accent-green);
    letter-spacing: 0.4px;
  }
  .formula-box .formula-label {
    font-size: 0.68rem;
    color: #888;
    font-family: "Lato", sans-serif;
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* TABLE */
  .excel-table {
    width: 100%;
    border-collapse: collapse;
    margin: 16px 0;
    font-size: 0.84rem;
  }
  .excel-table th {
    background: var(--dark-green);
    color: var(--white);
    padding: 10px 14px;
    text-align: left;
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.5px;
  }
  .excel-table td {
    padding: 9px 14px;
    border-bottom: 1px solid var(--border);
    color: var(--text-dark);
  }
  .excel-table tr:nth-child(even) td { background: var(--pale-green); }
  .excel-table tr:hover td { background: #d4edda; }

  /* HIGHLIGHT BOX */
  .highlight-box {
    background: var(--pale-green);
    border: 1px solid var(--accent-green);
    border-left: 4px solid var(--accent-green);
    border-radius: 8px;
    padding: 16px 20px;
    margin: 16px 0;
    font-size: 0.88rem;
  }
  .highlight-box strong { color: var(--dark-green); }
  .highlight-box.tip::before {
    content: "💡 TIP: ";
    font-weight: 700;
    color: var(--bright-green);
  }
  .highlight-box.warning { border-left-color: #ff9800; background: #fff8e1; }
  .highlight-box.warning::before {
    content: "⚠️ NOTE: ";
    font-weight: 700;
    color: #e65100;
  }

  /* STEPS */
  .steps {
    counter-reset: step-counter;
    margin: 16px 0;
  }
  .step-item {
    display: flex;
    gap: 14px;
    margin-bottom: 16px;
    align-items: flex-start;
  }
  .step-num {
    width: 28px; height: 28px;
    background: var(--dark-green);
    color: var(--white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .step-text { font-size: 0.9rem; line-height: 1.65; }
  .step-text strong { color: var(--dark-green); }

  /* SHORTCUT TABLE */
  .shortcut-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin: 14px 0;
  }
  .shortcut-item {
    background: var(--pale-green);
    border-radius: 8px;
    padding: 10px 14px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
  }
  .shortcut-item .keys {
    font-family: "Courier New", monospace;
    font-size: 0.78rem;
    font-weight: 700;
    background: var(--dark-green);
    color: var(--accent-green);
    padding: 2px 8px;
    border-radius: 4px;
    white-space: nowrap;
  }
  .shortcut-item .desc { font-size: 0.82rem; color: var(--text-muted); }

  /* QUIZ */
  .quiz-box {
    background: var(--white);
    border: 2px solid var(--border);
    border-radius: 12px;
    padding: 28px;
    margin: 20px 0;
  }
  .quiz-box h4 {
    font-family: "Playfair Display", serif;
    font-size: 1.1rem;
    color: var(--dark-green);
    margin-bottom: 16px;
  }
  .quiz-option {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    margin-bottom: 8px;
    cursor: pointer;
    transition: all 0.2s;
    font-size: 0.88rem;
  }
  .quiz-option:hover { border-color: var(--bright-green); background: var(--pale-green); }
  .quiz-option.correct { border-color: var(--accent-green); background: #e8f5e9; color: var(--dark-green); }
  .quiz-option.wrong { border-color: #f44336; background: #ffebee; }
  .quiz-option input { accent-color: var(--dark-green); }
  .quiz-feedback {
    margin-top: 14px;
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 0.88rem;
    display: none;
  }
  .quiz-feedback.show { display: block; }
  .quiz-feedback.correct-fb { background: #e8f5e9; color: var(--dark-green); border: 1px solid var(--accent-green); }
  .quiz-feedback.wrong-fb { background: #ffebee; color: #c62828; border: 1px solid #f44336; }
  .quiz-btn {
    background: var(--dark-green);
    color: var(--white);
    border: none;
    padding: 10px 24px;
    border-radius: 8px;
    font-size: 0.88rem;
    font-weight: 700;
    cursor: pointer;
    margin-top: 12px;
    transition: background 0.2s;
  }
  .quiz-btn:hover { background: var(--bright-green); }

  /* PROGRESS */
  .progress-bar-wrapper {
    background: var(--pale-green);
    border-radius: 30px;
    height: 8px;
    margin: 6px 0 14px;
    overflow: hidden;
  }
  .progress-bar {
    height: 100%;
    background: linear-gradient(90deg, var(--bright-green), var(--accent-green));
    border-radius: 30px;
    transition: width 0.5s;
  }

  /* FOOTER */
  footer {
    background: var(--dark-green);
    color: #b9e4be;
    text-align: center;
    padding: 24px;
    font-size: 0.8rem;
    margin-top: 40px;
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .layout { grid-template-columns: 1fr; }
    .sidebar { position: relative; top: 0; height: auto; }
    .content { padding: 24px 20px; }
    nav { padding: 10px 16px; flex-wrap: wrap; gap: 8px; }
    .hero { padding: 50px 20px 40px; }
    .shortcut-grid { grid-template-columns: 1fr; }
  }

  /* SCROLL BEHAVIOR */
  html { scroll-behavior: smooth; }
  .sidebar::-webkit-scrollbar { width: 4px; }
  .sidebar::-webkit-scrollbar-track { background: transparent; }
  .sidebar::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
</style>
</head>
<body>

