  </div>

</aside>

<!-- MAIN CONTENT -->
<main class="content">

<!-- ===== HOME ===== -->
<div class="section active" id="section-home">
  <div class="section-header">
    <span class="tag">Welcome</span>
    <h2>Excel for Data Analysis</h2>
    <p>Your complete guide to using Microsoft Excel as a powerful data analysis tool — structured for the LWi Data Analysis for Beginners cohort.</p>
  </div>
  <div class="cards">
    <div class="card" onclick="showSection('interface',null)">
      <div class="card-icon">🖥️</div>
      <h4>Excel Interface</h4>
      <p>Navigate the ribbon, workbook, worksheets, cells, rows and columns with confidence.</p>
    </div>
    <div class="card" onclick="showSection('formulas',null)">
      <div class="card-icon">➕</div>
      <h4>Formulas & Operators</h4>
      <p>Build formulas from scratch using arithmetic, comparison and logical operators.</p>
    </div>
    <div class="card" onclick="showSection('functions',null)">
      <div class="card-icon">📐</div>
      <h4>Key Functions</h4>
      <p>SUM, AVERAGE, IF, VLOOKUP, COUNTIF and 40+ essential data analysis functions.</p>
    </div>
    <div class="card" onclick="showSection('charts',null)">
      <div class="card-icon">📊</div>
      <h4>Charts & Graphs</h4>
      <p>Visualise data with bar, line, pie and scatter charts. Tell stories with data.</p>
    </div>
    <div class="card" onclick="showSection('pivottables',null)">
      <div class="card-icon">🔄</div>
      <h4>PivotTables</h4>
      <p>Summarise thousands of rows instantly. Group, filter and drill down into data.</p>
    </div>
    <div class="card" onclick="showSection('datawrangling',null)">
      <div class="card-icon">🧹</div>
      <h4>Data Cleaning</h4>
      <p>Remove duplicates, fix text, handle blanks and prepare raw data for analysis.</p>
    </div>
    <div class="card" onclick="showSection('shortcuts',null)">
      <div class="card-icon">⌨️</div>
      <h4>Keyboard Shortcuts</h4>
      <p>Work 3× faster with 30+ essential Excel shortcuts every analyst must know.</p>
    </div>
    <div class="card" onclick="showSection('quiz',null)">
      <div class="card-icon">🎯</div>
      <h4>Quiz Yourself</h4>
      <p>Test your Excel knowledge with 10 hands-on questions across all topics.</p>
    </div>
  </div>
</div>

<!-- ===== INTERFACE ===== -->
<div class="section" id="section-interface">
  <div class="section-header">
    <span class="tag">Module 1</span>
    <h2>The Excel Interface</h2>
    <p>Understanding the workspace before you start analysing data.</p>
  </div>

  <div class="content-block">
    <h3>🖥️ Key Interface Components</h3>
    <table class="excel-table">
      <thead><tr><th>Component</th><th>Description</th><th>Shortcut</th></tr></thead>
      <tbody>
        <tr><td><strong>Ribbon</strong></td><td>Toolbar at the top with tabs (Home, Insert, Data, etc.)</td><td>Alt to activate</td></tr>
        <tr><td><strong>Name Box</strong></td><td>Shows the active cell address (e.g. A1)</td><td>Ctrl+G to Go To</td></tr>
        <tr><td><strong>Formula Bar</strong></td><td>Displays / edits the content of the active cell</td><td>F2 to edit</td></tr>
        <tr><td><strong>Worksheet Tabs</strong></td><td>Separate sheets within a workbook</td><td>Ctrl+Page Up/Down</td></tr>
        <tr><td><strong>Cell</strong></td><td>Intersection of row and column (e.g. B3)</td><td>Arrow keys to navigate</td></tr>
        <tr><td><strong>Range</strong></td><td>A group of cells (e.g. A1:D10)</td><td>Shift+Click to select</td></tr>
        <tr><td><strong>Status Bar</strong></td><td>Shows Sum, Average, Count of selected cells</td><td>Right-click to customise</td></tr>
      </tbody>
    </table>
  </div>

  <div class="content-block">
    <h3>📋 Cell References Explained</h3>
    <div class="steps">
      <div class="step-item"><div class="step-num">1</div><div class="step-text"><strong>Relative Reference (A1)</strong> — changes when you copy a formula to another cell. Most common type.</div></div>
      <div class="step-item"><div class="step-num">2</div><div class="step-text"><strong>Absolute Reference ($A$1)</strong> — stays fixed no matter where you paste the formula. Use F4 to toggle.</div></div>
      <div class="step-item"><div class="step-num">3</div><div class="step-text"><strong>Mixed Reference ($A1 or A$1)</strong> — locks either the column or the row. Useful for multiplication tables.</div></div>
    </div>
    <div class="formula-box">
      <div class="formula-label">Example — Mixed Reference for a Multiplication Table</div>
      =$A2*B$1  →  Lock column A, Lock row 1
    </div>
    <div class="highlight-box tip">Press <strong>F4</strong> repeatedly in the formula bar to cycle through A1 → $A$1 → A$1 → $A1.</div>
  </div>

  <div class="content-block">
    <h3>🗂️ Workbook vs Worksheet</h3>
    <ul>
      <li><strong>Workbook</strong> — the entire .xlsx file. One workbook can contain many worksheets.</li>
      <li><strong>Worksheet</strong> — a single tab/sheet. Has up to 1,048,576 rows and 16,384 columns.</li>
      <li>Reference data from another sheet: <code>Sheet2!A1</code></li>
      <li>Reference from another workbook: <code>[SalesData.xlsx]Sheet1!$A$1</code></li>
    </ul>
  </div>
</div>

<!-- ===== FORMULAS ===== -->
<div class="section" id="section-formulas">
  <div class="section-header">
    <span class="tag">Module 2</span>
    <h2>Formulas & Operators</h2>
    <p>Every formula starts with an equals sign (=). Learn to build powerful calculations from scratch.</p>
  </div>

  <div class="content-block">
    <h3>🔢 Arithmetic Operators</h3>
    <table class="excel-table">
      <thead><tr><th>Operator</th><th>Meaning</th><th>Example</th><th>Result</th></tr></thead>
      <tbody>
        <tr><td>+</td><td>Addition</td><td>=A1+B1</td><td>Sum of A1 and B1</td></tr>
        <tr><td>-</td><td>Subtraction</td><td>=A1-B1</td><td>Difference</td></tr>
        <tr><td>*</td><td>Multiplication</td><td>=A1*B1</td><td>Product</td></tr>
        <tr><td>/</td><td>Division</td><td>=A1/B1</td><td>Quotient</td></tr>
        <tr><td>^</td><td>Exponentiation</td><td>=A1^2</td><td>A1 squared</td></tr>
        <tr><td>%</td><td>Percentage</td><td>=20%</td><td>0.2</td></tr>
      </tbody>
    </table>
  </div>

  <div class="content-block">
    <h3>⚖️ Comparison Operators (Return TRUE or FALSE)</h3>
    <table class="excel-table">
      <thead><tr><th>Operator</th><th>Meaning</th><th>Example</th></tr></thead>
      <tbody>
        <tr><td>=</td><td>Equal to</td><td>=A1=B1</td></tr>
        <tr><td>&lt;&gt;</td><td>Not equal to</td><td>=A1&lt;&gt;B1</td></tr>
        <tr><td>&gt;</td><td>Greater than</td><td>=A1&gt;100</td></tr>
        <tr><td>&lt;</td><td>Less than</td><td>=A1&lt;50</td></tr>
        <tr><td>&gt;=</td><td>Greater than or equal</td><td>=A1&gt;=0</td></tr>
        <tr><td>&lt;=</td><td>Less than or equal</td><td>=A1&lt;=MAX(B:B)</td></tr>
      </tbody>
    </table>
  </div>

  <div class="content-block">
    <h3>🔗 Text Concatenation</h3>
    <div class="formula-box">
      <div class="formula-label">Concatenate with &amp; operator</div>
      =A1&amp;" "&amp;B1        → "John Smith"<br>
      =CONCAT(A1," ",B1)  → "John Smith" (Excel 2019+)<br>
      =TEXTJOIN(", ",TRUE,A1:A5)  → "Apple, Banana, Cherry"
    </div>
    <div class="highlight-box tip">Use <strong>TEXTJOIN</strong> to join a range of values with a delimiter, skipping empty cells with the second argument set to TRUE.</div>
  </div>

  <div class="content-block">
    <h3>📊 Order of Operations (BODMAS/PEMDAS)</h3>
    <div class="steps">
      <div class="step-item"><div class="step-num">1</div><div class="step-text"><strong>Brackets/Parentheses</strong> — evaluated first</div></div>
      <div class="step-item"><div class="step-num">2</div><div class="step-text"><strong>Exponents/Orders</strong> — powers and roots</div></div>
      <div class="step-item"><div class="step-num">3</div><div class="step-text"><strong>Division and Multiplication</strong> — left to right</div></div>
      <div class="step-item"><div class="step-num">4</div><div class="step-text"><strong>Addition and Subtraction</strong> — left to right</div></div>
    </div>
    <div class="formula-box">
      <div class="formula-label">Example</div>
      =2+3*4    → 14  (multiply first)<br>
      =(2+3)*4  → 20  (brackets first)
    </div>
  </div>
</div>

<!-- ===== FUNCTIONS ===== -->
<div class="section" id="section-functions">
  <div class="section-header">
    <span class="tag">Module 3</span>
    <h2>Key Excel Functions</h2>
    <p>Pre-built formulas that save time. Functions take arguments in parentheses.</p>
  </div>

  <div class="content-block">
    <h3>📊 Statistical Functions</h3>
    <table class="excel-table">
      <thead><tr><th>Function</th><th>Syntax</th><th>What it does</th></tr></thead>
      <tbody>
        <tr><td>SUM</td><td>=SUM(A1:A10)</td><td>Adds all values in a range</td></tr>
        <tr><td>AVERAGE</td><td>=AVERAGE(A1:A10)</td><td>Arithmetic mean</td></tr>
        <tr><td>MEDIAN</td><td>=MEDIAN(A1:A10)</td><td>Middle value</td></tr>
        <tr><td>MODE</td><td>=MODE(A1:A10)</td><td>Most frequent value</td></tr>
        <tr><td>MAX</td><td>=MAX(A1:A10)</td><td>Largest value</td></tr>
        <tr><td>MIN</td><td>=MIN(A1:A10)</td><td>Smallest value</td></tr>
        <tr><td>COUNT</td><td>=COUNT(A1:A10)</td><td>Count numeric cells</td></tr>
        <tr><td>COUNTA</td><td>=COUNTA(A1:A10)</td><td>Count non-empty cells</td></tr>
        <tr><td>COUNTBLANK</td><td>=COUNTBLANK(A1:A10)</td><td>Count empty cells</td></tr>
        <tr><td>STDEV</td><td>=STDEV(A1:A10)</td><td>Standard deviation (sample)</td></tr>
        <tr><td>VAR</td><td>=VAR(A1:A10)</td><td>Variance (sample)</td></tr>
        <tr><td>LARGE</td><td>=LARGE(A1:A10,2)</td><td>2nd largest value</td></tr>
        <tr><td>SMALL</td><td>=SMALL(A1:A10,3)</td><td>3rd smallest value</td></tr>
      </tbody>
    </table>
  </div>

  <div class="content-block">
    <h3>🔍 Lookup & Reference Functions</h3>
    <div class="formula-box">
      <div class="formula-label">VLOOKUP — vertical lookup</div>
      =VLOOKUP(lookup_value, table_array, col_index, [range_lookup])
      Example: =VLOOKUP(A2, $D$2:$F$100, 2, FALSE)
    </div>
    <div class="formula-box">
      <div class="formula-label">HLOOKUP — horizontal lookup</div>
      =HLOOKUP(lookup_value, table_array, row_index, [range_lookup])
    </div>
    <div class="formula-box">
      <div class="formula-label">INDEX + MATCH — more flexible than VLOOKUP</div>
      =INDEX(return_range, MATCH(lookup_value, lookup_range, 0))
      Example: =INDEX(C2:C100, MATCH(A2, B2:B100, 0))
    </div>
    <div class="formula-box">
      <div class="formula-label">XLOOKUP — modern replacement (Excel 365)</div>
      =XLOOKUP(lookup_value, lookup_array, return_array, [not_found])
      Example: =XLOOKUP(A2, B:B, C:C, "Not Found")
    </div>
    <div class="highlight-box tip">Use <strong>FALSE</strong> (exact match) as the 4th argument in VLOOKUP for data analysis. TRUE (approximate match) is for sorted lookup tables.</div>
  </div>

  <div class="content-block">
    <h3>🔀 Logical Functions</h3>
    <div class="formula-box">
      <div class="formula-label">IF — basic conditional</div>
      =IF(A1&gt;50, "Pass", "Fail")
      =IF(A1="", "Missing", A1)
    </div>
    <div class="formula-box">
      <div class="formula-label">Nested IF — multiple conditions</div>
      =IF(A1&gt;=80,"A", IF(A1&gt;=60,"B", IF(A1&gt;=40,"C","F")))
    </div>
    <div class="formula-box">
      <div class="formula-label">IFS — cleaner than nested IF (Excel 2019+)</div>
      =IFS(A1&gt;=80,"A", A1&gt;=60,"B", A1&gt;=40,"C", TRUE,"F")
    </div>
    <div class="formula-box">
      <div class="formula-label">AND / OR — combine conditions</div>
      =IF(AND(A1&gt;0, A1&lt;100), "Valid", "Invalid")
      =IF(OR(A1="Yes", A1="Y"), "Agreed", "Declined")
    </div>
    <div class="formula-box">
      <div class="formula-label">IFERROR — handle errors gracefully</div>
      =IFERROR(VLOOKUP(A2,B:C,2,FALSE), "Not Found")
    </div>
  </div>

  <div class="content-block">
    <h3>📝 Text Functions</h3>
    <table class="excel-table">
      <thead><tr><th>Function</th><th>Example</th><th>Result</th></tr></thead>
      <tbody>
        <tr><td>LEFT</td><td>=LEFT("Excel",3)</td><td>"Exc"</td></tr>
        <tr><td>RIGHT</td><td>=RIGHT("Excel",3)</td><td>"cel"</td></tr>
        <tr><td>MID</td><td>=MID("Excel",2,3)</td><td>"xce"</td></tr>
        <tr><td>LEN</td><td>=LEN("Excel")</td><td>5</td></tr>
        <tr><td>UPPER</td><td>=UPPER("hello")</td><td>"HELLO"</td></tr>
        <tr><td>LOWER</td><td>=LOWER("HELLO")</td><td>"hello"</td></tr>
        <tr><td>PROPER</td><td>=PROPER("john doe")</td><td>"John Doe"</td></tr>
        <tr><td>TRIM</td><td>=TRIM(" hello ")</td><td>"hello"</td></tr>
        <tr><td>SUBSTITUTE</td><td>=SUBSTITUTE("A-B","A","X")</td><td>"X-B"</td></tr>
        <tr><td>FIND</td><td>=FIND("@","a@b.com")</td><td>2</td></tr>
        <tr><td>VALUE</td><td>=VALUE("123")</td><td>123 (number)</td></tr>
        <tr><td>TEXT</td><td>=TEXT(1234,"#,##0")</td><td>"1,234"</td></tr>
      </tbody>
    </table>
  </div>

  <div class="content-block">
    <h3>📅 Date & Time Functions</h3>
    <div class="formula-box">
      <div class="formula-label">Common Date Functions</div>
      =TODAY()           → Current date<br>
      =NOW()             → Current date and time<br>
      =YEAR(A1)          → Extract year<br>
      =MONTH(A1)         → Extract month (1–12)<br>
      =DAY(A1)           → Extract day<br>
      =DATEDIF(A1,B1,"D") → Days between two dates<br>
      =NETWORKDAYS(A1,B1) → Working days between dates<br>
      =WEEKDAY(A1,2)      → Day of week (1=Monday)
    </div>
    <div class="highlight-box tip">Excel stores dates as serial numbers (1 = Jan 1, 1900). Formatting displays them as dates. This is why arithmetic on dates works!</div>
  </div>

  <div class="content-block">
    <h3>🎯 Conditional Aggregation</h3>
    <div class="formula-box">
      <div class="formula-label">COUNTIF / COUNTIFS</div>
      =COUNTIF(A:A, "Lagos")            → Count rows where A = "Lagos"<br>
      =COUNTIFS(A:A,"Lagos",B:B,"Male") → Count rows meeting both criteria
    </div>
    <div class="formula-box">
      <div class="formula-label">SUMIF / SUMIFS</div>
      =SUMIF(A:A, "North", B:B)          → Sum column B where A = "North"<br>
      =SUMIFS(C:C, A:A, "North", B:B, "&gt;1000") → Sum C where A=North AND B&gt;1000
    </div>
    <div class="formula-box">
      <div class="formula-label">AVERAGEIF / AVERAGEIFS</div>
      =AVERAGEIF(B:B, "&gt;0", C:C)        → Average C where B is positive
    </div>
  </div>
</div>

<!-- ===== CHARTS ===== -->
<div class="section" id="section-charts">
  <div class="section-header">
    <span class="tag">Module 4</span>
    <h2>Charts & Data Visualisation</h2>
    <p>Transform numbers into stories with the right chart for your data.</p>
  </div>

  <div class="content-block">
    <h3>📊 Choosing the Right Chart</h3>
    <table class="excel-table">
      <thead><tr><th>Chart Type</th><th>Best For</th><th>Example Use Case</th></tr></thead>
      <tbody>
        <tr><td>📊 Bar/Column</td><td>Comparing categories</td><td>Sales by region, population by country</td></tr>
        <tr><td>📈 Line</td><td>Trends over time</td><td>Monthly revenue, stock prices</td></tr>
        <tr><td>🥧 Pie/Doughnut</td><td>Parts of a whole (max 6 slices)</td><td>Market share, budget allocation</td></tr>
        <tr><td>⬜ Scatter</td><td>Correlation between two variables</td><td>Height vs weight, ad spend vs sales</td></tr>
        <tr><td>📦 Box Plot</td><td>Distribution and outliers</td><td>Exam scores, salary ranges</td></tr>
        <tr><td>🌡️ Heatmap</td><td>Pattern in matrix data</td><td>Sales by day and hour</td></tr>
        <tr><td>📉 Histogram</td><td>Frequency distribution</td><td>Age distribution of customers</td></tr>
        <tr><td>🗺️ Area</td><td>Cumulative trends</td><td>Cumulative sales over time</td></tr>
      </tbody>
    </table>
    <div class="highlight-box warning">Avoid pie charts with more than 5–6 slices — they become hard to read. Use a bar chart instead.</div>
  </div>

  <div class="content-block">
    <h3>🛠️ Creating a Chart — Step by Step</h3>
    <div class="steps">
      <div class="step-item"><div class="step-num">1</div><div class="step-text"><strong>Select your data</strong> — highlight the range including headers (e.g. A1:B12).</div></div>
      <div class="step-item"><div class="step-num">2</div><div class="step-text"><strong>Insert tab → Charts group</strong> — click the chart type you want, or use Recommended Charts.</div></div>
      <div class="step-item"><div class="step-num">3</div><div class="step-text"><strong>Chart Design tab</strong> — change chart style, colour scheme, layout using the design ribbon.</div></div>
      <div class="step-item"><div class="step-num">4</div><div class="step-text"><strong>Format tab</strong> — right-click any element (title, axis, bars) to format individual parts.</div></div>
      <div class="step-item"><div class="step-num">5</div><div class="step-text"><strong>Add Chart Elements</strong> — add data labels, axis titles, gridlines, legend via the + button next to the chart.</div></div>
    </div>
  </div>

  <div class="content-block">
    <h3>💡 Chart Best Practices</h3>
    <ul>
      <li>Always <strong>label your axes</strong> and add a descriptive title</li>
      <li>Keep it <strong>simple</strong> — avoid 3D charts, gradient fills and excessive colours</li>
      <li>Use <strong>data labels</strong> on bar/pie charts so readers don't have to estimate</li>
      <li>Start y-axis at <strong>zero</strong> for bar charts to avoid misleading comparisons</li>
      <li>Use a <strong>consistent colour palette</strong> — one colour per series</li>
      <li>Remove <strong>gridlines and borders</strong> that don't add information (chart junk)</li>
    </ul>
  </div>
</div>

<!-- ===== PIVOT TABLES ===== -->
<div class="section" id="section-pivottables">
  <div class="section-header">
    <span class="tag">Module 5</span>
    <h2>PivotTables</h2>
    <p>The most powerful feature in Excel for summarising and exploring large datasets without writing a single formula.</p>
  </div>

  <div class="content-block">
    <h3>🔄 What is a PivotTable?</h3>
    <p>A PivotTable is an interactive summary table. You drag and drop fields to instantly group, aggregate and filter your data. Analysing 50,000 rows takes seconds.</p>
    <div class="highlight-box tip">Your data must be structured as a <strong>flat table</strong>: one row per record, one column per variable, no merged cells, no blank rows/columns.</div>
  </div>

  <div class="content-block">
    <h3>🛠️ Creating a PivotTable — Step by Step</h3>
    <div class="steps">
      <div class="step-item"><div class="step-num">1</div><div class="step-text"><strong>Click anywhere inside your data</strong> — Excel will auto-detect the data range.</div></div>
      <div class="step-item"><div class="step-num">2</div><div class="step-text"><strong>Insert → PivotTable</strong> — choose New Worksheet, click OK.</div></div>
      <div class="step-item"><div class="step-num">3</div><div class="step-text"><strong>Drag fields</strong> from the Field List into the four areas: Filters, Columns, Rows, Values.</div></div>
      <div class="step-item"><div class="step-num">4</div><div class="step-text"><strong>Change the aggregation</strong> — right-click a value → Value Field Settings → Sum, Count, Average, Max, etc.</div></div>
      <div class="step-item"><div class="step-num">5</div><div class="step-text"><strong>Add a Slicer</strong> — PivotTable Analyse → Insert Slicer for interactive filtering.</div></div>
      <div class="step-item"><div class="step-num">6</div><div class="step-text"><strong>Refresh</strong> — when your source data changes, right-click → Refresh, or press Alt+F5.</div></div>
    </div>
  </div>

  <div class="content-block">
    <h3>📐 The Four PivotTable Areas</h3>
    <table class="excel-table">
      <thead><tr><th>Area</th><th>Purpose</th><th>Example</th></tr></thead>
      <tbody>
        <tr><td>🔽 Filters</td><td>Top-level filter for the whole table</td><td>Year = 2024</td></tr>
        <tr><td>↔️ Columns</td><td>Creates column headers</td><td>Months across the top</td></tr>
        <tr><td>↕️ Rows</td><td>Creates row labels</td><td>Product names down the side</td></tr>
        <tr><td>Σ Values</td><td>The numbers being summarised</td><td>Sum of Sales, Count of Orders</td></tr>
      </tbody>
    </table>
  </div>

  <div class="content-block">
    <h3>📊 Calculated Fields</h3>
    <div class="steps">
      <div class="step-item"><div class="step-num">1</div><div class="step-text">Click inside the PivotTable.</div></div>
      <div class="step-item"><div class="step-num">2</div><div class="step-text">PivotTable Analyse → Fields, Items & Sets → Calculated Field.</div></div>
      <div class="step-item"><div class="step-num">3</div><div class="step-text">Name the field and enter a formula using existing fields, e.g. <code>= Revenue / Units</code>.</div></div>
    </div>
    <div class="highlight-box tip">Connect a PivotChart to your PivotTable for an interactive dashboard. Both update together when you change slicers or filters.</div>
  </div>
</div>

<!-- ===== DATA CLEANING ===== -->
<div class="section" id="section-datawrangling">
  <div class="section-header">
    <span class="tag">Module 6</span>
    <h2>Data Cleaning & Preparation</h2>
    <p>Real-world data is messy. 80% of data analysis time is spent cleaning data.</p>
  </div>

  <div class="content-block">
    <h3>🧹 Common Data Problems & Solutions</h3>
    <table class="excel-table">
      <thead><tr><th>Problem</th><th>Solution</th><th>Function/Feature</th></tr></thead>
      <tbody>
        <tr><td>Extra spaces</td><td>Remove leading/trailing spaces</td><td>=TRIM(A1)</td></tr>
        <tr><td>Inconsistent case</td><td>Standardise text case</td><td>=PROPER(A1) or =LOWER(A1)</td></tr>
        <tr><td>Duplicate rows</td><td>Remove duplicates</td><td>Data → Remove Duplicates</td></tr>
        <tr><td>Blank cells</td><td>Find and fill or flag</td><td>Ctrl+G → Special → Blanks</td></tr>
        <tr><td>Numbers stored as text</td><td>Convert to numbers</td><td>=VALUE(A1) or Data → Text to Columns</td></tr>
        <tr><td>Merged cells</td><td>Unmerge and fill down</td><td>Unmerge → Ctrl+G → Blanks → =A1 above</td></tr>
        <tr><td>Date formats mixed</td><td>Standardise dates</td><td>=DATEVALUE(A1) or Text to Columns</td></tr>
        <tr><td>Outliers</td><td>Identify extreme values</td><td>Conditional Formatting or Z-scores</td></tr>
      </tbody>
    </table>
  </div>

  <div class="content-block">
    <h3>🔎 Using Find & Replace</h3>
    <div class="steps">
      <div class="step-item"><div class="step-num">1</div><div class="step-text">Press <strong>Ctrl+H</strong> to open Find & Replace.</div></div>
      <div class="step-item"><div class="step-num">2</div><div class="step-text">Type the value to find and what to replace it with.</div></div>
      <div class="step-item"><div class="step-num">3</div><div class="step-text">Click <strong>Options</strong> to match case, match entire cell, or search formulas/values.</div></div>
      <div class="step-item"><div class="step-num">4</div><div class="step-text">Click <strong>Replace All</strong> — Excel shows how many replacements were made.</div></div>
    </div>
    <div class="highlight-box tip">Use wildcards in Find: <strong>*</strong> matches any sequence of characters, <strong>?</strong> matches any single character.</div>
  </div>

  <div class="content-block">
    <h3>✅ Conditional Formatting for Data Validation</h3>
    <div class="steps">
      <div class="step-item"><div class="step-num">1</div><div class="step-text">Select the range to check.</div></div>
      <div class="step-item"><div class="step-num">2</div><div class="step-text">Home → Conditional Formatting → Highlight Cell Rules → Duplicate Values.</div></div>
      <div class="step-item"><div class="step-num">3</div><div class="step-text">Use "New Rule" with a formula like <code>=ISBLANK(A1)</code> to highlight blanks.</div></div>
      <div class="step-item"><div class="step-num">4</div><div class="step-text">Use colour scales / data bars to visualise magnitude across a column instantly.</div></div>
    </div>
  </div>

  <div class="content-block">
    <h3>📋 Data Validation</h3>
    <p>Prevent bad data from entering your spreadsheet in the first place.</p>
    <div class="steps">
      <div class="step-item"><div class="step-num">1</div><div class="step-text">Select the cells you want to restrict.</div></div>
      <div class="step-item"><div class="step-num">2</div><div class="step-text">Data → Data Validation → Settings tab.</div></div>
      <div class="step-item"><div class="step-num">3</div><div class="step-text">Choose: Whole number, Decimal, List (dropdown), Date, Text length, or Custom formula.</div></div>
      <div class="step-item"><div class="step-num">4</div><div class="step-text">Add an Input Message and Error Alert for user guidance.</div></div>
    </div>
    <div class="highlight-box tip">Create a <strong>drop-down list</strong> by choosing "List" in Data Validation and entering comma-separated values or a cell range as the source.</div>
  </div>
</div>

<!-- ===== SHORTCUTS ===== -->
<div class="section" id="section-shortcuts">
  <div class="section-header">
    <span class="tag">Module 7</span>
    <h2>Keyboard Shortcuts</h2>
    <p>Master these shortcuts and you will work significantly faster than your colleagues.</p>
  </div>

  <div class="content-block">
    <h3>⌨️ Navigation Shortcuts</h3>
    <div class="shortcut-grid">
      <div class="shortcut-item"><span class="desc">Go to last cell in row</span><span class="keys">Ctrl + →</span></div>
      <div class="shortcut-item"><span class="desc">Go to last cell in column</span><span class="keys">Ctrl + ↓</span></div>
      <div class="shortcut-item"><span class="desc">Go to cell A1</span><span class="keys">Ctrl + Home</span></div>
      <div class="shortcut-item"><span class="desc">Go to last used cell</span><span class="keys">Ctrl + End</span></div>
      <div class="shortcut-item"><span class="desc">Go to cell (Name Box)</span><span class="keys">Ctrl + G</span></div>
      <div class="shortcut-item"><span class="desc">Move between sheets</span><span class="keys">Ctrl + PgUp/Dn</span></div>
    </div>
  </div>

  <div class="content-block">
    <h3>✂️ Editing Shortcuts</h3>
    <div class="shortcut-grid">
      <div class="shortcut-item"><span class="desc">Copy</span><span class="keys">Ctrl + C</span></div>
      <div class="shortcut-item"><span class="desc">Cut</span><span class="keys">Ctrl + X</span></div>
      <div class="shortcut-item"><span class="desc">Paste</span><span class="keys">Ctrl + V</span></div>
      <div class="shortcut-item"><span class="desc">Paste Special</span><span class="keys">Ctrl + Alt + V</span></div>
      <div class="shortcut-item"><span class="desc">Undo</span><span class="keys">Ctrl + Z</span></div>
      <div class="shortcut-item"><span class="desc">Redo</span><span class="keys">Ctrl + Y</span></div>
      <div class="shortcut-item"><span class="desc">Edit cell</span><span class="keys">F2</span></div>
      <div class="shortcut-item"><span class="desc">Fill Down</span><span class="keys">Ctrl + D</span></div>
      <div class="shortcut-item"><span class="desc">Fill Right</span><span class="keys">Ctrl + R</span></div>
      <div class="shortcut-item"><span class="desc">Find & Replace</span><span class="keys">Ctrl + H</span></div>
    </div>
  </div>

  <div class="content-block">
    <h3>📋 Selection Shortcuts</h3>
    <div class="shortcut-grid">
      <div class="shortcut-item"><span class="desc">Select entire column</span><span class="keys">Ctrl + Space</span></div>
      <div class="shortcut-item"><span class="desc">Select entire row</span><span class="keys">Shift + Space</span></div>
      <div class="shortcut-item"><span class="desc">Select all cells</span><span class="keys">Ctrl + A</span></div>
      <div class="shortcut-item"><span class="desc">Extend selection</span><span class="keys">Shift + Arrow</span></div>
      <div class="shortcut-item"><span class="desc">Select to last cell</span><span class="keys">Ctrl + Shift + End</span></div>
      <div class="shortcut-item"><span class="desc">Select special (blanks etc)</span><span class="keys">Ctrl + G → Special</span></div>
    </div>
  </div>

  <div class="content-block">
    <h3>📊 Data & Formatting Shortcuts</h3>
    <div class="shortcut-grid">
      <div class="shortcut-item"><span class="desc">Format cells dialog</span><span class="keys">Ctrl + 1</span></div>
      <div class="shortcut-item"><span class="desc">Bold</span><span class="keys">Ctrl + B</span></div>
      <div class="shortcut-item"><span class="desc">Italic</span><span class="keys">Ctrl + I</span></div>
      <div class="shortcut-item"><span class="desc">Apply currency format</span><span class="keys">Ctrl + Shift + $</span></div>
      <div class="shortcut-item"><span class="desc">Apply percentage format</span><span class="keys">Ctrl + Shift + %</span></div>
      <div class="shortcut-item"><span class="desc">AutoFilter toggle</span><span class="keys">Ctrl + Shift + L</span></div>
      <div class="shortcut-item"><span class="desc">Insert table</span><span class="keys">Ctrl + T</span></div>
      <div class="shortcut-item"><span class="desc">Toggle $ in formula</span><span class="keys">F4</span></div>
      <div class="shortcut-item"><span class="desc">Calculate now</span><span class="keys">F9</span></div>
      <div class="shortcut-item"><span class="desc">Save workbook</span><span class="keys">Ctrl + S</span></div>
    </div>
  </div>
</div>

<!-- ===== QUIZ ===== -->
<div class="section" id="section-quiz">
  <div class="section-header">
    <span class="tag">Practice</span>
    <h2>Quiz Yourself</h2>
    <p>Test your understanding across all Excel for Data Analysis topics.</p>
  </div>

  <div style="margin-bottom: 20px;">
    <strong style="font-size:0.9rem; color: var(--dark-green);">Your Progress</strong>
    <div class="progress-bar-wrapper"><div class="progress-bar" id="quiz-progress" style="width:0%"></div></div>
    <span id="quiz-score-text" style="font-size:0.82rem; color:var(--text-muted);">0 / 10 answered</span>
  </div>

  <!-- Q1 -->
  <div class="quiz-box" id="q1">
    <h4>Q1. Which formula correctly calculates the sum of cells A1 to A10?</h4>
    <div class="quiz-option" onclick="selectOption('q1','a')"><input type="radio" name="q1"> =ADD(A1:A10)</div>
    <div class="quiz-option" onclick="selectOption('q1','b')"><input type="radio" name="q1"> =SUM(A1:A10)</div>
    <div class="quiz-option" onclick="selectOption('q1','c')"><input type="radio" name="q1"> =TOTAL(A1,A10)</div>
    <div class="quiz-option" onclick="selectOption('q1','d')"><input type="radio" name="q1"> =SUM(A1;A10)</div>
    <button class="quiz-btn" onclick="checkQuiz('q1','b','=SUM(A1:A10) is the correct syntax. Excel uses colons (:) to define ranges.')">Check Answer</button>
    <div class="quiz-feedback" id="q1-fb"></div>
  </div>

  <!-- Q2 -->
  <div class="quiz-box" id="q2">
    <h4>Q2. What does the $ symbol do in the cell reference $A$1?</h4>
    <div class="quiz-option" onclick="selectOption('q2','a')"><input type="radio" name="q2"> It formats the cell as currency</div>
    <div class="quiz-option" onclick="selectOption('q2','b')"><input type="radio" name="q2"> It locks both the column and row when copying</div>
    <div class="quiz-option" onclick="selectOption('q2','c')"><input type="radio" name="q2"> It multiplies the cell value by its position</div>
    <div class="quiz-option" onclick="selectOption('q2','d')"><input type="radio" name="q2"> It makes the cell read-only</div>
    <button class="quiz-btn" onclick="checkQuiz('q2','b','$A$1 is an absolute reference — the $ before A locks the column, and the $ before 1 locks the row. The reference won\'t change when you copy the formula.')">Check Answer</button>
    <div class="quiz-feedback" id="q2-fb"></div>
  </div>

  <!-- Q3 -->
  <div class="quiz-box" id="q3">
    <h4>Q3. Which VLOOKUP argument should be FALSE for an exact match?</h4>
    <div class="quiz-option" onclick="selectOption('q3','a')"><input type="radio" name="q3"> 1st argument (lookup_value)</div>
    <div class="quiz-option" onclick="selectOption('q3','b')"><input type="radio" name="q3"> 2nd argument (table_array)</div>
    <div class="quiz-option" onclick="selectOption('q3','c')"><input type="radio" name="q3"> 3rd argument (col_index_num)</div>
    <div class="quiz-option" onclick="selectOption('q3','d')"><input type="radio" name="q3"> 4th argument (range_lookup)</div>
    <button class="quiz-btn" onclick="checkQuiz('q3','d','The 4th argument [range_lookup] controls match type. FALSE = exact match. TRUE (or 1) = approximate match (requires sorted data).')">Check Answer</button>
    <div class="quiz-feedback" id="q3-fb"></div>
  </div>

  <!-- Q4 -->
  <div class="quiz-box" id="q4">
    <h4>Q4. What does =IFERROR(VLOOKUP(A2,B:C,2,FALSE),"Not Found") do?</h4>
    <div class="quiz-option" onclick="selectOption('q4','a')"><input type="radio" name="q4"> Returns an error if VLOOKUP succeeds</div>
    <div class="quiz-option" onclick="selectOption('q4','b')"><input type="radio" name="q4"> Displays "Not Found" if VLOOKUP returns an error</div>
    <div class="quiz-option" onclick="selectOption('q4','c')"><input type="radio" name="q4"> Always returns "Not Found"</div>
    <div class="quiz-option" onclick="selectOption('q4','d')"><input type="radio" name="q4"> Counts the number of errors in column B:C</div>
    <button class="quiz-btn" onclick="checkQuiz('q4','b','IFERROR wraps another formula. If the formula returns any error (like #N/A when VLOOKUP can\'t find a match), it returns the value you specify — here, the text "Not Found".')">Check Answer</button>
    <div class="quiz-feedback" id="q4-fb"></div>
  </div>

  <!-- Q5 -->
  <div class="quiz-box" id="q5">
    <h4>Q5. Which function counts only numeric cells in a range?</h4>
    <div class="quiz-option" onclick="selectOption('q5','a')"><input type="radio" name="q5"> =COUNTA(A1:A10)</div>
    <div class="quiz-option" onclick="selectOption('q5','b')"><input type="radio" name="q5"> =COUNT(A1:A10)</div>
    <div class="quiz-option" onclick="selectOption('q5','c')"><input type="radio" name="q5"> =COUNTBLANK(A1:A10)</div>
    <div class="quiz-option" onclick="selectOption('q5','d')"><input type="radio" name="q5"> =SUMCOUNT(A1:A10)</div>
    <button class="quiz-btn" onclick="checkQuiz('q5','b','COUNT counts only numeric values. COUNTA counts all non-empty cells (text, numbers, dates etc). COUNTBLANK counts empty cells.')">Check Answer</button>
    <div class="quiz-feedback" id="q5-fb"></div>
  </div>

  <!-- Q6 -->
  <div class="quiz-box" id="q6">
    <h4>Q6. What is the keyboard shortcut to toggle absolute/relative cell references?</h4>
    <div class="quiz-option" onclick="selectOption('q6','a')"><input type="radio" name="q6"> F2</div>
    <div class="quiz-option" onclick="selectOption('q6','b')"><input type="radio" name="q6"> F4</div>
    <div class="quiz-option" onclick="selectOption('q6','c')"><input type="radio" name="q6"> Ctrl + $</div>
    <div class="quiz-option" onclick="selectOption('q6','d')"><input type="radio" name="q6"> Alt + F4</div>
    <button class="quiz-btn" onclick="checkQuiz('q6','b','Press F4 while your cursor is inside a cell reference in the formula bar to cycle: A1 → $A$1 → A$1 → $A1 → A1.')">Check Answer</button>
    <div class="quiz-feedback" id="q6-fb"></div>
  </div>

  <!-- Q7 -->
  <div class="quiz-box" id="q7">
    <h4>Q7. What type of chart is best for showing a trend over 12 months?</h4>
    <div class="quiz-option" onclick="selectOption('q7','a')"><input type="radio" name="q7"> Pie chart</div>
    <div class="quiz-option" onclick="selectOption('q7','b')"><input type="radio" name="q7"> Scatter plot</div>
    <div class="quiz-option" onclick="selectOption('q7','c')"><input type="radio" name="q7"> Line chart</div>
    <div class="quiz-option" onclick="selectOption('q7','d')"><input type="radio" name="q7"> Box plot</div>
    <button class="quiz-btn" onclick="checkQuiz('q7','c','Line charts are ideal for showing trends over time. Each point represents a time period (month, year) and the line shows the direction of change.')">Check Answer</button>
    <div class="quiz-feedback" id="q7-fb"></div>
  </div>

  <!-- Q8 -->
  <div class="quiz-box" id="q8">
    <h4>Q8. Which function removes leading and trailing spaces from text?</h4>
    <div class="quiz-option" onclick="selectOption('q8','a')"><input type="radio" name="q8"> =CLEAN(A1)</div>
    <div class="quiz-option" onclick="selectOption('q8','b')"><input type="radio" name="q8"> =STRIP(A1)</div>
    <div class="quiz-option" onclick="selectOption('q8','c')"><input type="radio" name="q8"> =TRIM(A1)</div>
    <div class="quiz-option" onclick="selectOption('q8','d')"><input type="radio" name="q8"> =REMOVE(A1," ")</div>
    <button class="quiz-btn" onclick="checkQuiz('q8','c','TRIM removes leading and trailing spaces, and reduces multiple internal spaces to a single space. CLEAN removes non-printable characters.')">Check Answer</button>
    <div class="quiz-feedback" id="q8-fb"></div>
  </div>

  <!-- Q9 -->
  <div class="quiz-box" id="q9">
    <h4>Q9. In a PivotTable, where do you place a field to create column headers?</h4>
    <div class="quiz-option" onclick="selectOption('q9','a')"><input type="radio" name="q9"> Filters area</div>
    <div class="quiz-option" onclick="selectOption('q9','b')"><input type="radio" name="q9"> Rows area</div>
    <div class="quiz-option" onclick="selectOption('q9','c')"><input type="radio" name="q9"> Columns area</div>
    <div class="quiz-option" onclick="selectOption('q9','d')"><input type="radio" name="q9"> Values area</div>
    <button class="quiz-btn" onclick="checkQuiz('q9','c','Dragging a field into the Columns area creates column headers across the top. Rows area creates row labels down the side. Values area contains the numbers to summarise.')">Check Answer</button>
    <div class="quiz-feedback" id="q9-fb"></div>
  </div>

  <!-- Q10 -->
  <div class="quiz-box" id="q10">
    <h4>Q10. What does =COUNTIFS(A:A,"Lagos",B:B,"Female") return?</h4>
    <div class="quiz-option" onclick="selectOption('q10','a')"><input type="radio" name="q10"> The sum of all female values in Lagos</div>
    <div class="quiz-option" onclick="selectOption('q10','b')"><input type="radio" name="q10"> Count of rows where A = "Lagos" AND B = "Female"</div>
    <div class="quiz-option" onclick="selectOption('q10','c')"><input type="radio" name="q10"> Count of rows where A = "Lagos" OR B = "Female"</div>
    <div class="quiz-option" onclick="selectOption('q10','d')"><input type="radio" name="q10"> It returns an error because COUNTIFS requires numbers</div>
    <button class="quiz-btn" onclick="checkQuiz('q10','b','COUNTIFS applies multiple criteria (AND logic). It counts rows where ALL conditions are met simultaneously — here, both A = Lagos AND B = Female.')">Check Answer</button>
    <div class="quiz-feedback" id="q10-fb"></div>
  </div>

</div>
<!-- End sections -->

</main>
</div>

<footer>
  <p>© 2024 Learn With iKay (LWi) · Data Analysis for Beginners · Excel Module</p>
  <p style="margin-top:6px; color:#6aab70;">Building Tomorrow's Data Analysts Today 🌱</p>
</footer>

<script>
  let answeredQuestions = new Set();

  function showSection(sectionId, clickedLink) {
    // Hide all sections
    document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
    // Show target
    var target = document.getElementById('section-' + sectionId);
    if (target) target.classList.add('active');

    // Update sidebar active state
    document.querySelectorAll('.sidebar a').forEach(a => a.classList.remove('active'));
    if (clickedLink) {
      clickedLink.classList.add('active');
    } else {
      // Find matching sidebar link
      document.querySelectorAll('.sidebar a').forEach(function(a) {
        if (a.getAttribute('onclick') && a.getAttribute('onclick').includes("'" + sectionId + "'")) {
          a.classList.add('active');
        }
      });
    }

    // Update nav links
    document.querySelectorAll('.nav-links a').forEach(a => a.classList.remove('active'));

    // Scroll to top of content
    document.querySelector('.content').scrollTop = 0;
    window.scrollTo({ top: 77, behavior: 'smooth' });
  }

  function selectOption(qId, option) {
    var opts = document.querySelectorAll('#' + qId + ' .quiz-option');
    opts.forEach(function(o) {
      o.classList.remove('correct', 'wrong');
    });
  }

  function checkQuiz(qId, correctOption, explanation) {
    var box = document.getElementById(qId);
    var opts = box.querySelectorAll('.quiz-option');
    var selected = null;
    var letters = ['a','b','c','d'];

    opts.forEach(function(opt, i) {
      var radio = opt.querySelector('input[type="radio"]');
      if (radio.checked) selected = letters[i];
    });

    if (!selected) {
      alert('Please select an answer first!');
      return;
    }

    opts.forEach(function(opt, i) {
      opt.classList.remove('correct','wrong');
      if (letters[i] === correctOption) opt.classList.add('correct');
      else if (letters[i] === selected) opt.classList.add('wrong');
    });

    var fb = document.getElementById(qId + '-fb');
    fb.classList.add('show');

    if (selected === correctOption) {
      fb.className = 'quiz-feedback show correct-fb';
      fb.innerHTML = '✅ <strong>Correct!</strong> ' + explanation;
    } else {
      fb.className = 'quiz-feedback show wrong-fb';
      fb.innerHTML = '❌ <strong>Incorrect.</strong> ' + explanation;
    }

    if (!answeredQuestions.has(qId)) {
      answeredQuestions.add(qId);
      var count = answeredQuestions.size;
      document.getElementById('quiz-progress').style.width = (count * 10) + '%';
      document.getElementById('quiz-score-text').textContent = count + ' / 10 answered';
    }
  }
</script>

</body>
</html>
